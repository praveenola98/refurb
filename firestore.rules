// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - role: string (required, 'admin' | 'customer')
//   - createdAt: string (ISO date)
//   - blocked: boolean
//
// Collection: products
// Document ID: {productId}
// Fields:
//   - name: string (required)
//   - brand: string (required)
//   - price: number (required)
//   - discountPrice: number
//   - stock: number (required)
//   - condition: string (required, 'A' | 'B' | 'C')
//   - images: list of strings
//   - description: string
//   - featured: boolean
//
// Collection: orders
// Document ID: {orderId}
// Fields:
//   - userId: string (required)
//   - items: list (required)
//   - totalAmount: number (required)
//   - status: string (required, 'pending' | 'packed' | 'shipped' | 'delivered' | 'cancelled')
//   - paymentMethod: string (required, 'razorpay' | 'cod')
//   - createdAt: string (ISO date)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "olapraveen34@gmail.com"
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'brand', 'price', 'stock', 'condition']) &&
             data.name is string && data.name.size() < 200 &&
             data.brand is string &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             data.condition in ['A', 'B', 'C'];
    }

    // Rules
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'customer' || isAdmin());
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
